# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.env

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Data — keep directory structure, exclude large/raw files ─────────────────
data/raw/*.csv
data/processed/*.csv
# To include sample data, remove the lines above and add:
# !data/raw/.gitkeep
# !data/processed/.gitkeep

# ── Trained models (binary, can be large) ────────────────────────────────────
models/*.pkl
# Keep metadata and feature names (small JSON/pkl is fine to track)
!models/model_metadata.json

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
.cache/

# ── Claude Code internal ──────────────────────────────────────────────────────
.claude/
